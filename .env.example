# ═══════════════════════════════════════════════════════════
# Immich + S3 Backup — Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# 1. Copy this file to .env:
#      cp .env.example .env
#
# 2. Edit .env with your values.
#
# See: https://docs.immich.app/install/environment-variables
# ═══════════════════════════════════════════════════════════

# Where uploaded photos are stored
UPLOAD_LOCATION=./library

# Where PostgreSQL data is stored (do NOT use network shares)
DB_DATA_LOCATION=./postgres

# Your timezone (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/La_Paz

# Immich version tag (release, or pin to e.g. v2.1.0)
IMMICH_VERSION=release

# ── PostgreSQL credentials ──
# ⚠️  CHANGE THIS to a random password (A-Za-z0-9 only, no special chars)
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ── S3 Backup ──
# Your S3 bucket name for backups. Must already exist.
# Ensure AWS credentials are configured:  aws configure
S3_BUCKET=your-bucket-name-here
